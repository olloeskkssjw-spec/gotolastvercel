{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "cd apps/ezcash-show && pnpm run build",
  "outputDirectory": "apps/ezcash-show/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  }
}
